{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arma-ai-bridge/ballistic-profiles-v1",
  "type": "object",
  "required": ["schema", "profiles"],
  "properties": {
    "schema": { "const": "arma-ai-bridge/ballistic-profiles-v1" },
    "profiles": { "type": "array", "maxItems": 128, "items": { "$ref": "#/$defs/profile" } }
  },
  "additionalProperties": false,
  "$defs": {
    "boundedText": { "type": "string", "maxLength": 256 },
    "finiteArray": { "type": "array", "maxItems": 64, "items": { "type": "number" } },
    "profile": {
      "type": "object",
      "required": ["profileId", "displayName", "enabled", "notes", "weaponClassMatch", "muzzleClassMatch", "magazineClassMatch", "ammunitionClassMatch", "weaponDisplayNameMatch", "matchPriority", "weaponDisplayName", "twistDirection", "ammunitionDisplayName", "dragModel", "ballisticCoefficients", "velocityBoundariesMetersPerSecond", "standardAtmosphere", "temperatureMuzzleVelocityShifts", "barrelLengthsMillimeters", "barrelMuzzleVelocitiesMetersPerSecond", "preferredSolver", "windCorrectionEnabled", "spinDriftEnabled", "coriolisEnabled", "transonicModelingEnabled", "temperatureCorrectionEnabled", "barrelLengthCorrectionEnabled", "nominalDeterministicMuzzleVelocity", "maximumSupportedRangeMeters"],
      "properties": {
        "profileId": { "type": "string", "format": "uuid" },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 128 },
        "enabled": { "type": "boolean" }, "notes": { "type": "string", "maxLength": 4096 },
        "weaponClassMatch": { "$ref": "#/$defs/boundedText" }, "muzzleClassMatch": { "$ref": "#/$defs/boundedText" },
        "magazineClassMatch": { "$ref": "#/$defs/boundedText" }, "ammunitionClassMatch": { "$ref": "#/$defs/boundedText" },
        "weaponDisplayNameMatch": { "$ref": "#/$defs/boundedText" }, "matchPriority": { "type": "integer", "minimum": -100000, "maximum": 100000 },
        "weaponDisplayName": { "$ref": "#/$defs/boundedText" }, "ammunitionDisplayName": { "$ref": "#/$defs/boundedText" },
        "barrelLengthMillimeters": { "type": ["number", "null"] }, "barrelTwistMillimetersPerTurn": { "type": ["number", "null"] },
        "twistDirection": { "enum": ["none", "right", "left"] }, "sightHeightMillimeters": { "type": ["number", "null"] },
        "defaultZeroRangeMeters": { "type": ["number", "null"] }, "scopeBaseAngleMilliradians": { "type": ["number", "null"] },
        "muzzleVelocityMultiplier": { "type": ["number", "null"] }, "bulletDiameterMillimeters": { "type": ["number", "null"] },
        "bulletLengthMillimeters": { "type": ["number", "null"] }, "bulletMassGrams": { "type": ["number", "null"] },
        "dragModel": { "enum": ["G1", "G2", "G5", "G6", "G7", "G8"] },
        "ballisticCoefficients": { "$ref": "#/$defs/finiteArray" }, "velocityBoundariesMetersPerSecond": { "$ref": "#/$defs/finiteArray" },
        "standardAtmosphere": { "enum": ["ASM", "ICAO"] }, "transonicStabilityCoefficient": { "type": ["number", "null"] },
        "nominalMuzzleVelocityMetersPerSecond": { "type": ["number", "null"] }, "muzzleVelocityVariationStandardDeviationPercent": { "type": ["number", "null"] },
        "temperatureMuzzleVelocityShifts": { "$ref": "#/$defs/finiteArray" }, "barrelLengthsMillimeters": { "$ref": "#/$defs/finiteArray" },
        "barrelMuzzleVelocitiesMetersPerSecond": { "$ref": "#/$defs/finiteArray" }, "gravityCoefficient": { "type": ["number", "null"] },
        "vanillaAirFriction": { "type": ["number", "null"] },
        "manualPressureHectopascals": { "type": ["number", "null"], "minimum": 300, "maximum": 1100 },
        "preferredSolver": { "enum": ["automatic", "aceCompatibleAdvanced", "simplifiedCoefficient", "vanillaArma"] },
        "windCorrectionEnabled": { "type": "boolean" }, "spinDriftEnabled": { "type": "boolean" }, "coriolisEnabled": { "type": "boolean" },
        "transonicModelingEnabled": { "type": "boolean" }, "temperatureCorrectionEnabled": { "type": "boolean" },
        "barrelLengthCorrectionEnabled": { "type": "boolean" }, "nominalDeterministicMuzzleVelocity": { "type": "boolean" },
        "maximumSupportedRangeMeters": { "type": "number", "minimum": 25, "maximum": 5000 }
      },
      "additionalProperties": false
    }
  }
}
