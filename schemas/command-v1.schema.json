{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ViperSix11/ArmA-AI-Bridge/schemas/command-v1.schema.json",
  "title": "ArmA AI Bridge command v1",
  "type": "object",
  "properties": {
    "schema": { "const": "arma-ai-bridge/command-v1" }
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "requestId", "command", "parameters"],
      "properties": {
        "schema": { "const": "arma-ai-bridge/command-v1" },
        "requestId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "command": { "const": "query_environment" },
        "parameters": {
          "type": "object",
          "required": ["origin", "shape", "categories", "maxResultsPerCategory"],
          "properties": {
            "origin": { "const": "player" },
            "shape": { "enum": ["circle", "cone"] },
            "direction": { "enum": ["view", "body"] },
            "radiusMeters": { "type": "number", "minimum": 25, "maximum": 1500 },
            "rangeMeters": { "type": "number", "minimum": 25, "maximum": 1500 },
            "angleDegrees": { "type": "number", "minimum": 5, "maximum": 180 },
            "categories": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "enum": ["building", "vegetation", "road", "wall", "rock"] }
            },
            "maxResultsPerCategory": { "type": "integer", "minimum": 1, "maximum": 50 }
          },
          "additionalProperties": false
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "requestId", "command", "parameters"],
      "properties": {
        "schema": { "const": "arma-ai-bridge/command-v1" },
        "requestId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "command": { "const": "request_map_gazetteer" },
        "parameters": { "type": "object", "maxProperties": 0 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "requestId", "command", "parameters"],
      "properties": {
        "schema": { "const": "arma-ai-bridge/command-v1" },
        "requestId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "command": { "const": "query_terrain_height" },
        "parameters": {
          "type": "object",
          "required": ["position"],
          "properties": {
            "position": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -10000000, "maximum": 10000000 } }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}
