{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ViperSix11/ArmA-AI-Bridge/schemas/map-gazetteer-v1.schema.json",
  "title": "ArmA AI Bridge official map gazetteer page v1",
  "type": "object",
  "required": ["schema", "messageId", "missionId", "sessionId", "timestamp", "sequence", "gazetteerId", "pageIndex", "pageCount", "world", "locations"],
  "properties": {
    "schema": { "const": "arma-ai-bridge/arma3/map-gazetteer-v1" },
    "messageId": { "$ref": "#/$defs/id" },
    "missionId": { "$ref": "#/$defs/id" },
    "sessionId": { "$ref": "#/$defs/id" },
    "timestamp": { "type": "number", "minimum": 0 },
    "sequence": { "type": "integer", "minimum": 1 },
    "gazetteerId": { "$ref": "#/$defs/id" },
    "pageIndex": { "type": "integer", "minimum": 0, "maximum": 63 },
    "pageCount": { "type": "integer", "minimum": 1, "maximum": 64 },
    "world": {
      "type": "object",
      "required": ["name", "sizeMeters", "grid"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "sizeMeters": { "type": "number", "exclusiveMinimum": 0, "maximum": 100000 },
        "grid": {
          "type": "object",
          "required": ["format", "samples"],
          "properties": {
            "format": { "const": "arma-map-grid" },
            "samples": {
              "type": "array", "minItems": 1, "maxItems": 9,
              "items": {
                "type": "object", "required": ["position", "grid"],
                "properties": {
                  "position": { "$ref": "#/$defs/vector2" },
                  "grid": { "type": "string", "minLength": 1, "maxLength": 32 }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "locations": {
      "type": "array", "maxItems": 64,
      "items": {
        "type": "object",
        "required": ["configKey", "officialName", "locationType", "position", "size"],
        "properties": {
          "configKey": { "$ref": "#/$defs/id" },
          "officialName": { "type": "string", "minLength": 1, "maxLength": 160 },
          "locationType": { "type": "string", "minLength": 1, "maxLength": 64 },
          "position": { "$ref": "#/$defs/vector2" },
          "size": { "oneOf": [{ "$ref": "#/$defs/vector2" }, { "type": "null" }] }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "vector2": { "type": "array", "prefixItems": [{ "type": "number" }, { "type": "number" }], "items": false, "minItems": 2, "maxItems": 2 }
  },
  "additionalProperties": false
}
