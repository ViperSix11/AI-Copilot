{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ViperSix11/ArmA-AI-Bridge/schemas/map-gazetteer-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "messageId", "missionId", "sessionId", "timestamp", "sequence", "requestId", "batchId", "pageIndex", "pageCount", "world", "totalLocations", "status", "errorCode", "locations"],
  "properties": {
    "schema": { "const": "arma-ai-bridge/arma3/map-gazetteer-v1" },
    "messageId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "missionId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "sessionId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "timestamp": { "type": "number", "minimum": 0 },
    "sequence": { "type": "integer", "minimum": 1 },
    "requestId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "batchId": { "type": "string", "minLength": 1, "maxLength": 128 },
    "pageIndex": { "type": "integer", "minimum": 0, "maximum": 63 },
    "pageCount": { "type": "integer", "minimum": 1, "maximum": 64 },
    "world": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sizeMeters"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "sizeMeters": { "type": "number", "exclusiveMinimum": 0, "maximum": 500000 }
      }
    },
    "totalLocations": { "type": "integer", "minimum": 0, "maximum": 8192 },
    "status": { "enum": ["complete", "failed"] },
    "errorCode": { "type": ["string", "null"], "maxLength": 64 },
    "locations": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key", "name", "type", "position", "radiusA", "radiusB", "angle"],
        "properties": {
          "key": { "type": "string", "minLength": 1, "maxLength": 128 },
          "name": { "type": "string", "minLength": 1, "maxLength": 160 },
          "type": { "type": "string", "minLength": 1, "maxLength": 64 },
          "position": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number", "minimum": -50000, "maximum": 500000 } },
          "radiusA": { "type": "number", "minimum": 0, "maximum": 100000 },
          "radiusB": { "type": "number", "minimum": 0, "maximum": 100000 },
          "angle": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 }
        }
      }
    }
  }
}
