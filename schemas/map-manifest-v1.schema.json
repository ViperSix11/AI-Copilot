{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ViperSix11/AI-Copilot/schemas/map-manifest-v1.schema.json",
  "title": "ArmA AI Bridge map manifest v1",
  "type": "object",
  "required": ["schema", "messageId", "missionId", "sessionId", "timestamp", "sequence", "indexVersion", "world", "product", "addons", "export"],
  "properties": {
    "schema": { "const": "arma-ai-bridge/arma3/map-manifest-v1" },
    "messageId": { "$ref": "#/$defs/id" },
    "missionId": { "$ref": "#/$defs/id" },
    "sessionId": { "$ref": "#/$defs/id" },
    "timestamp": { "type": "number", "minimum": 0 },
    "sequence": { "type": "integer", "minimum": 1 },
    "indexVersion": { "const": 1 },
    "world": {
      "type": "object",
      "required": ["name", "sizeMeters", "terrainInfo", "config", "gridReferences"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "sizeMeters": { "type": "number", "exclusiveMinimum": 0, "maximum": 131072 },
        "terrainInfo": { "type": "array", "minItems": 5, "maxItems": 5, "items": { "type": "number" } },
        "config": {
          "type": "object",
          "required": ["class", "description", "mapSize", "mapZone", "latitude", "longitude", "sourceAddons"],
          "properties": {
            "class": { "type": "string", "minLength": 1, "maxLength": 128 },
            "description": { "type": "string", "maxLength": 256 },
            "mapSize": { "type": ["number", "null"] },
            "mapZone": { "type": ["number", "null"] },
            "latitude": { "type": ["number", "null"] },
            "longitude": { "type": ["number", "null"] },
            "sourceAddons": { "type": "array", "maxItems": 256, "items": { "type": "string", "minLength": 1, "maxLength": 192 } }
          },
          "additionalProperties": false
        },
        "gridReferences": {
          "type": "array", "minItems": 4, "maxItems": 4,
          "items": {
            "type": "object", "required": ["position", "label"],
            "properties": {
              "position": { "$ref": "#/$defs/vector2" },
              "label": { "type": "string", "maxLength": 64 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "product": {
      "type": "object",
      "required": ["shortName", "version", "build", "buildType", "platform", "architecture", "branch"],
      "properties": {
        "shortName": { "type": "string", "minLength": 1, "maxLength": 64 },
        "version": { "type": "number", "minimum": 0 },
        "build": { "type": "integer", "minimum": 0 },
        "buildType": { "type": "string", "maxLength": 32 },
        "platform": { "type": "string", "maxLength": 32 },
        "architecture": { "type": "string", "maxLength": 32 },
        "branch": { "type": "string", "maxLength": 64 }
      },
      "additionalProperties": false
    },
    "addons": {
      "type": "array", "maxItems": 4096,
      "items": {
        "type": "object", "required": ["prefix", "version", "patched", "hash"],
        "properties": {
          "prefix": { "type": "string", "minLength": 1, "maxLength": 384 },
          "version": { "type": "string", "maxLength": 128 },
          "patched": { "type": "boolean" },
          "hash": { "type": "string", "maxLength": 128 }
        },
        "additionalProperties": false
      }
    },
    "export": {
      "type": "object",
      "required": ["tileSizeMeters", "terrainSampleSpacingMeters", "totalTiles", "maxRecordsPerPage"],
      "properties": {
        "tileSizeMeters": { "type": "integer", "minimum": 256, "maximum": 1024 },
        "terrainSampleSpacingMeters": { "type": "integer", "minimum": 32, "maximum": 256 },
        "totalTiles": { "type": "integer", "minimum": 1, "maximum": 16384 },
        "maxRecordsPerPage": { "type": "integer", "minimum": 16, "maximum": 96 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}$" },
    "vector2": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } }
  }
}
