{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.arma-ai-bridge.invalid/schemas/normalized-event-v2.schema.json",
  "title": "Papa Bear technical observation-window event v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "eventAlias",
    "eventType",
    "transition",
    "entityAliases",
    "changedDomains",
    "snapshotSequence",
    "windowSnapshotCount",
    "observedAtUtc"
  ],
  "properties": {
    "schema": {
      "const": "arma-ai-bridge/normalized-event-v2"
    },
    "eventAlias": {
      "type": "string",
      "pattern": "^event-[a-zA-Z0-9_-]{1,80}$"
    },
    "eventType": {
      "enum": [
        "contact-development",
        "state-change-bundle"
      ]
    },
    "transition": {
      "enum": [
        "possible-new",
        "reacquired",
        "developed",
        "window-complete"
      ]
    },
    "entityAliases": {
      "type": "array",
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "changedDomains": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      }
    },
    "snapshotSequence": {
      "type": "integer",
      "minimum": 1
    },
    "windowSnapshotCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6
    },
    "observedAtUtc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
