{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ViperSix11/ArmA-AI-Bridge/schemas/query-result-v1.schema.json",
  "title": "ArmA AI Bridge Arma 3 query result v1",
  "type": "object",
  "required": ["schema", "requestId", "command", "timestamp", "ok"],
  "properties": {
    "schema": { "const": "arma-ai-bridge/arma3/query-result-v1" },
    "requestId": { "type": "string" },
    "command": { "type": "string" },
    "timestamp": { "type": "number" },
    "ok": { "type": "boolean" },
    "error": { "type": "string" },
    "result": {
      "type": "object",
      "properties": {
        "query": { "type": "object" },
        "categories": { "type": "object" },
        "analysis": { "type": "object" },
        "position": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } },
        "terrainHeightAslMeters": { "type": "number", "minimum": -1000, "maximum": 10000 }
        ,"available": { "type": "boolean" }
        ,"reason": { "type": "string", "maxLength": 128 }
        ,"model": { "enum": ["ace3-advanced-ballistics"] }
        ,"nominalSolution": { "type": "boolean" }
        ,"rangeMeters": { "type": "number", "minimum": 25, "maximum": 5000 }
        ,"bearingDegrees": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 }
        ,"elevationCorrectionMilliradians": { "type": "number" }
        ,"horizontalCorrectionMilliradians": { "type": "number" }
        ,"timeOfFlightSeconds": { "type": "number", "minimum": 0, "maximum": 30 }
        ,"predictedImpactVelocityMetersPerSecond": { "type": "number", "minimum": 0, "maximum": 10000 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
