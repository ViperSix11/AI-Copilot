{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ViperSix11/ArmA-AI-Bridge/schemas/session-handshake-v1.schema.json",
  "title": "ArmA AI Bridge session handshake v1",
  "type": "object",
  "required": ["schema", "messageId", "missionId", "sessionId", "timestamp", "sequence", "protocol", "world", "viewer", "features"],
  "properties": {
    "schema": { "const": "arma-ai-bridge/arma3/session-handshake-v1" },
    "messageId": { "$ref": "#/$defs/id" },
    "missionId": { "$ref": "#/$defs/id" },
    "sessionId": { "$ref": "#/$defs/id" },
    "timestamp": { "type": "number", "minimum": 0 },
    "sequence": { "type": "integer", "minimum": 1 },
    "protocol": {
      "type": "object",
      "required": ["major", "minor"],
      "properties": {
        "major": { "const": 1 },
        "minor": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "world": {
      "type": "object",
      "required": ["name", "sizeMeters"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "sizeMeters": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "viewer": {
      "type": "object",
      "required": ["side", "visibility"],
      "properties": {
        "side": { "enum": ["WEST", "EAST", "GUER", "CIV"] },
        "visibility": { "enum": ["own-side", "own-group"] }
      },
      "additionalProperties": false
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "object",
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 64 },
          "version": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "minLength": 1, "maxLength": 128 }
  },
  "additionalProperties": false
}
