{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ViperSix11/ArmA-AI-Bridge/schemas/telemetry-v1.schema.json",
  "title": "ArmA AI Bridge Arma 3 telemetry v1",
  "type": "object",
  "required": ["schema", "timestamp", "map", "player", "contacts", "sensorContacts"],
  "properties": {
    "schema": { "const": "arma-ai-bridge/arma3/telemetry-v1" },
    "missionId": { "type": "string", "maxLength": 128 },
    "sessionId": { "type": "string", "maxLength": 128 },
    "timestamp": { "type": "number" },
    "frame": { "type": "number" },
    "map": {
      "type": "object",
      "required": ["name", "sizeMeters"],
      "properties": {
        "name": { "type": "string" },
        "sizeMeters": { "type": "number" },
        "grid": { "type": "string" },
        "daytime": { "type": "number" }
      },
      "additionalProperties": true
    },
    "player": {
      "type": "object",
      "required": ["positionATL", "viewHeading"],
      "properties": {
        "id": { "type": "string", "maxLength": 128 },
        "groupId": { "type": "string", "maxLength": 128 },
        "positionATL": { "$ref": "#/$defs/vector3" },
        "positionASL": { "$ref": "#/$defs/vector3" },
        "viewHeading": { "type": "number" }
      },
      "additionalProperties": true
    },
    "vehicle": {
      "type": ["object", "null"],
      "properties": {
        "id": { "type": "string", "maxLength": 128 }
      },
      "additionalProperties": true
    },
    "contacts": { "type": "array", "items": { "type": "object" } },
    "sensorContacts": { "type": "array", "items": { "type": "object" } }
  },
  "$defs": {
    "vector3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "number" }
    }
  },
  "additionalProperties": true
}
