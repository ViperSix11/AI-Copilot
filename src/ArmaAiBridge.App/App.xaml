<Application x:Class="ArmaAiBridge.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#101317" />
        <SolidColorBrush x:Key="PanelBrush" Color="#181D23" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#303943" />
        <SolidColorBrush x:Key="TextBrush" Color="#E8EDF2" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9BA8B4" />
        <SolidColorBrush x:Key="AccentBrush" Color="#70D6A3" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#26303A" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#42505C" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0E1216" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#3A4651" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#0E1216" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#3A4651" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#161B20" />
            <Setter Property="Padding" Value="16,8" />
        </Style>
    </Application.Resources>
</Application>
