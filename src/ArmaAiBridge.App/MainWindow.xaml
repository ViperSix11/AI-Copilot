<Window x:Class="ArmaAiBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArmA AI Bridge - Papa Bear" Height="900" Width="1320"
        MinHeight="720" MinWidth="1040"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderFaceplateStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="48" Height="48" Background="{StaticResource AccentDarkBrush}"
                        BorderBrush="{StaticResource AccentStrongBrush}" BorderThickness="1"
                        CornerRadius="3" VerticalAlignment="Center">
                    <TextBlock Text="PB" FontFamily="{StaticResource BrandFontFamily}" FontSize="18"
                               FontWeight="Bold" Foreground="{StaticResource AccentStrongBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="ArmA AI Bridge - Papa Bear" Style="{StaticResource BrandTitleTextStyle}" />
                    <TextBlock Text="TACTICAL TELEMETRY  /  CONTEXTUAL INTERPRETATION  /  RADIO ASSISTANT"
                               Style="{StaticResource SubtitleTextStyle}" Margin="0,3,0,0" />
                </StackPanel>
                <Border Grid.Column="3" Style="{StaticResource VersionBadgeStyle}" VerticalAlignment="Center">
                    <TextBlock Text="v0.8.1" FontFamily="{StaticResource TerminalFontFamily}"
                               FontWeight="SemiBold" Foreground="{StaticResource AccentStrongBrush}" />
                </Border>
                <Border Grid.Column="5" Style="{StaticResource StatusBadgeStyle}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ConnectionIndicator" Width="11" Height="11" Fill="{StaticResource DangerBrush}"
                                 Margin="0,0,9,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="ConnectionStatusText" Text="Stopped" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="2">
            <TabItem Header="Dashboard">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="390" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Border Style="{StaticResource TacticalPanelStyle}" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Bridge control" Style="{StaticResource SectionHeaderTextStyle}" />
                                <TextBlock Text="Named pipe: ArmaAiBridge.Arma3.Telemetry"
                                           Style="{StaticResource MutedTextStyle}" Margin="0,6,0,16" />
                                <WrapPanel>
                                    <Button x:Name="StartButton" Content="Start listener" Click="StartButton_Click" />
                                    <Button x:Name="StopButton" Content="Stop" Click="StopButton_Click" IsEnabled="False"
                                            Style="{StaticResource DestructiveButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource TacticalPanelStyle}">
                            <StackPanel>
                                <TextBlock Text="Latest telemetry" Style="{StaticResource SectionHeaderTextStyle}" />
                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="126" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Map" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock x:Name="MapText" Grid.Column="1" Text="&#x2014;" />
                                    <TextBlock Grid.Row="1" Text="Position" Style="{StaticResource MutedTextStyle}" Margin="0,9,0,0" />
                                    <TextBlock x:Name="PositionText" Grid.Row="1" Grid.Column="1" Text="&#x2014;" Margin="0,9,0,0" />
                                    <TextBlock Grid.Row="2" Text="View heading" Style="{StaticResource MutedTextStyle}" Margin="0,9,0,0" />
                                    <TextBlock x:Name="HeadingText" Grid.Row="2" Grid.Column="1" Text="&#x2014;" Margin="0,9,0,0" />
                                    <TextBlock Grid.Row="3" Text="Known contacts" Style="{StaticResource MutedTextStyle}" Margin="0,9,0,0" />
                                    <TextBlock x:Name="ContactsText" Grid.Row="3" Grid.Column="1" Text="&#x2014;" Margin="0,9,0,0" />
                                    <TextBlock Grid.Row="4" Text="Last query" Style="{StaticResource MutedTextStyle}" Margin="0,9,0,0" />
                                    <TextBlock x:Name="LastQueryText" Grid.Row="4" Grid.Column="1" Text="&#x2014;"
                                               Margin="0,9,0,0" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="5" Text="Received" Style="{StaticResource MutedTextStyle}" Margin="0,9,0,0" />
                                    <TextBlock x:Name="ReceivedText" Grid.Row="5" Grid.Column="1" Text="&#x2014;" Margin="0,9,0,0" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Border Grid.Column="2" Style="{StaticResource TacticalPanelStyle}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Raw bridge message"
                                       Style="{StaticResource SectionHeaderTextStyle}" Margin="0,0,0,12" />
                            <TextBox x:Name="RawTelemetryTextBox" Style="{StaticResource TerminalTextBoxStyle}"
                                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" AcceptsReturn="True" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Map query">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="420" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource TacticalPanelStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Dynamic environment query" Style="{StaticResource SectionHeaderTextStyle}" />
                                <TextBlock Text="Send one bounded spatial query to the running Arma client. No fixed distance probes are used."
                                           Style="{StaticResource MutedTextStyle}" Margin="0,6,0,18" />

                                <TextBlock Text="Shape" Margin="0,0,0,6" />
                                <ComboBox x:Name="QueryShapeBox" SelectedIndex="1" Margin="0,0,0,14">
                                    <ComboBoxItem Content="Circle around player" Tag="circle" />
                                    <ComboBoxItem Content="Cone in a direction" Tag="cone" />
                                </ComboBox>

                                <TextBlock Text="Direction" Margin="0,0,0,6" />
                                <ComboBox x:Name="QueryDirectionBox" SelectedIndex="0" Margin="0,0,0,14">
                                    <ComboBoxItem Content="Current view direction" Tag="view" />
                                    <ComboBoxItem Content="Player body heading" Tag="body" />
                                </ComboBox>

                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Range / radius (m)" Margin="0,0,0,6" />
                                        <TextBox x:Name="QueryRangeBox" Text="800" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Cone angle (&#x00B0;)" Margin="0,0,0,6" />
                                        <TextBox x:Name="QueryAngleBox" Text="40" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Object categories" Margin="0,0,0,8" />
                                <WrapPanel Margin="0,0,0,14">
                                    <CheckBox x:Name="BuildingsCheckBox" Content="Buildings" IsChecked="True" Margin="0,0,18,8" />
                                    <CheckBox x:Name="VegetationCheckBox" Content="Vegetation" IsChecked="True" Margin="0,0,18,8" />
                                    <CheckBox x:Name="RoadsCheckBox" Content="Roads" Margin="0,0,18,8" />
                                    <CheckBox x:Name="WallsCheckBox" Content="Walls" Margin="0,0,18,8" />
                                    <CheckBox x:Name="RocksCheckBox" Content="Rocks" Margin="0,0,18,8" />
                                </WrapPanel>

                                <TextBlock Text="Maximum returned objects per category" Margin="0,0,0,6" />
                                <TextBox x:Name="QueryLimitBox" Text="25" Margin="0,0,0,18" />

                                <Button x:Name="SendQueryButton" Content="Send query to Arma"
                                        Click="SendQueryButton_Click" IsEnabled="False" HorizontalAlignment="Left" />
                                <TextBlock x:Name="QueryStatusText" Foreground="{StaticResource AccentStrongBrush}"
                                           TextWrapping="Wrap" Margin="0,8,0,0" Text="Connect Arma 3 to enable queries." />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource TacticalPanelStyle}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Latest query result"
                                       Style="{StaticResource SectionHeaderTextStyle}" Margin="0,0,0,12" />
                            <TextBox x:Name="QueryResultTextBox" Style="{StaticResource TerminalTextBoxStyle}"
                                     IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" AcceptsReturn="True" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="API keys">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource TacticalPanelStyle}" Margin="20"
                            MaxWidth="820" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Credentials and response profile" Style="{StaticResource SectionHeaderTextStyle}" />
                            <TextBlock Text="Keys are encrypted with Windows DPAPI for the current user. Voice audio and conversation content are never written to application logs."
                                       Style="{StaticResource MutedTextStyle}" Margin="0,6,0,20" />
                            <TextBlock Text="OpenAI API key" Margin="0,0,0,6" />
                            <PasswordBox x:Name="OpenAiKeyBox" Width="760" Margin="0,0,0,16" />
                            <TextBlock Text="ElevenLabs API key" Margin="0,0,0,6" />
                            <PasswordBox x:Name="ElevenLabsKeyBox" Width="760" Margin="0,0,0,16" />
                            <TextBlock Text="ElevenLabs voice ID" Margin="0,0,0,6" />
                            <TextBox x:Name="ElevenLabsVoiceIdBox" Width="760" Margin="0,0,0,18" />
                            <TextBlock Text="Response profile" Style="{StaticResource SectionHeaderTextStyle}" Margin="0,6,0,8" />
                            <TextBlock Text="Style settings affect wording only. They cannot change facts, privacy, fair play, calculations or tool policy."
                                       Style="{StaticResource MutedTextStyle}" Margin="0,0,0,14" />
                            <TextBlock Text="Operator pre-prompt (maximum 4,000 characters; applied before tactical context)" Margin="0,0,0,6" />
                            <TextBox x:Name="OperatorPrePromptBox" Width="760" MaxLength="4000" MinHeight="96"
                                     AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,14" />
                            <WrapPanel Margin="0,0,0,14">
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Preset" Margin="0,0,0,6" />
                                    <ComboBox x:Name="ResponsePresetBox" Width="190" SelectedIndex="0">
                                        <ComboBoxItem Content="Authentic military" Tag="authentic-military" />
                                        <ComboBoxItem Content="Concise military" Tag="concise-military" />
                                        <ComboBoxItem Content="Plain" Tag="plain" />
                                        <ComboBoxItem Content="Cinematic" Tag="cinematic" />
                                        <ComboBoxItem Content="Custom" Tag="custom" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Language" Margin="0,0,0,6" />
                                    <ComboBox x:Name="ResponseLanguageBox" Width="140" SelectedIndex="0">
                                        <ComboBoxItem Content="Automatic" Tag="auto" />
                                        <ComboBoxItem Content="English" Tag="en" />
                                        <ComboBoxItem Content="German" Tag="de" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Length" Margin="0,0,0,6" />
                                    <ComboBox x:Name="ResponseLengthBox" Width="140" SelectedIndex="1">
                                        <ComboBoxItem Content="Very short" Tag="very-short" />
                                        <ComboBoxItem Content="Short" Tag="short" />
                                        <ComboBoxItem Content="Normal" Tag="normal" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Terminator" Margin="0,0,0,6" />
                                    <ComboBox x:Name="ResponseTerminatorBox" Width="140" SelectedIndex="0">
                                        <ComboBoxItem Content="None" Tag="none" />
                                        <ComboBoxItem Content="Over" Tag="over" />
                                        <ComboBoxItem Content="Out" Tag="out" />
                                        <ComboBoxItem Content="Custom" Tag="custom" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Margin="16,0,0,0">
                                    <TextBlock Text="Banter" Margin="0,0,0,6" />
                                    <ComboBox x:Name="ResponseBanterBox" Width="120" SelectedIndex="1">
                                        <ComboBoxItem Content="Off" Tag="off" />
                                        <ComboBoxItem Content="Dry" Tag="dry" />
                                        <ComboBoxItem Content="Feisty" Tag="feisty" />
                                    </ComboBox>
                                </StackPanel>
                            </WrapPanel>
                            <TextBlock Text="Custom style (maximum 2,000 characters)" Margin="0,0,0,6" />
                            <TextBox x:Name="ResponseCustomStyleBox" Width="760" MaxLength="2000" MinHeight="76"
                                     AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,14" />
                            <TextBlock Text="Custom terminator (maximum 32 characters)" Margin="0,0,0,6" />
                            <TextBox x:Name="ResponseCustomTerminatorBox" Width="760" MaxLength="32" Margin="0,0,0,18" />
                            <WrapPanel>
                                <Button Content="Save encrypted settings" Click="SaveSettingsButton_Click" />
                                <Button Content="Clear fields" Click="ClearSettingsButton_Click" />
                                <Button Content="Reset to Default" Click="RestoreResponseProfileButton_Click" />
                            </WrapPanel>
                            <TextBlock x:Name="SettingsStatusText" Foreground="{StaticResource AccentStrongBrush}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Logs">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="Privacy-safe application log"
                                   Style="{StaticResource SectionHeaderTextStyle}" VerticalAlignment="Center" />
                        <WrapPanel DockPanel.Dock="Right">
                            <Button Content="Open log folder" Click="OpenLogFolderButton_Click" />
                            <Button Content="Clear view" Click="ClearLogButton_Click" />
                        </WrapPanel>
                    </DockPanel>
                    <Border Grid.Row="2" Style="{StaticResource TerminalPanelStyle}">
                        <ListBox x:Name="LogListBox" Style="{StaticResource TerminalListBoxStyle}" />
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,12,0,0">
            <TextBlock x:Name="FooterText" Text="Ready" Foreground="{StaticResource MutedTextBrush}"
                       FontFamily="{StaticResource TerminalFontFamily}" FontSize="13" />
        </Border>
    </Grid>
</Window>
