<Window x:Class="ArmaAiBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArmA AI Bridge" Height="860" Width="1260"
        MinHeight="720" MinWidth="1040"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="ArmA AI Bridge" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Papa Bear telemetry, world state and push-to-talk · v0.6.0"
                           Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
            </StackPanel>
            <Border Grid.Column="1" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="12,8" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="ConnectionIndicator" Width="10" Height="10" Fill="#D86A6A" Margin="0,0,8,0" />
                    <TextBlock x:Name="ConnectionStatusText" Text="Stopped" />
                </StackPanel>
            </Border>
        </Grid>

        <TabControl Grid.Row="2" Background="Transparent" BorderBrush="#303943">
            <TabItem Header="Dashboard">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Bridge" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="Named pipe: ArmaAiBridge.Arma3.Telemetry"
                                           Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,14" />
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="StartButton" Content="Start listener" Click="StartButton_Click" />
                                    <Button x:Name="StopButton" Content="Stop" Click="StopButton_Click" IsEnabled="False" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Latest telemetry" FontSize="18" FontWeight="SemiBold" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Map" Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock x:Name="MapText" Grid.Column="1" Text="—" />
                                    <TextBlock Grid.Row="1" Text="Position" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                                    <TextBlock x:Name="PositionText" Grid.Row="1" Grid.Column="1" Text="—" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="2" Text="View heading" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                                    <TextBlock x:Name="HeadingText" Grid.Row="2" Grid.Column="1" Text="—" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="3" Text="Known contacts" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                                    <TextBlock x:Name="ContactsText" Grid.Row="3" Grid.Column="1" Text="—" Margin="0,8,0,0" />
                                    <TextBlock Grid.Row="4" Text="Last query" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                                    <TextBlock x:Name="LastQueryText" Grid.Row="4" Grid.Column="1" Text="—" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="5" Text="Received" Foreground="{StaticResource MutedTextBrush}" Margin="0,8,0,0" />
                                    <TextBlock x:Name="ReceivedText" Grid.Row="5" Grid.Column="1" Text="—" Margin="0,8,0,0" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Raw bridge message" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBox x:Name="RawTelemetryTextBox" IsReadOnly="True"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" AcceptsReturn="True" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Map query">
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Dynamic environment query" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="This sends a one-off spatial query to the running Arma client. No fixed distance probes are used."
                                       Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,18" />

                            <TextBlock Text="Shape" Margin="0,0,0,6" />
                            <ComboBox x:Name="QueryShapeBox" SelectedIndex="1" Margin="0,0,0,14">
                                <ComboBoxItem Content="Circle around player" Tag="circle" />
                                <ComboBoxItem Content="Cone in a direction" Tag="cone" />
                            </ComboBox>

                            <TextBlock Text="Direction" Margin="0,0,0,6" />
                            <ComboBox x:Name="QueryDirectionBox" SelectedIndex="0" Margin="0,0,0,14">
                                <ComboBoxItem Content="Current view direction" Tag="view" />
                                <ComboBoxItem Content="Player body heading" Tag="body" />
                            </ComboBox>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Range / radius (m)" Margin="0,0,0,6" />
                                    <TextBox x:Name="QueryRangeBox" Text="800" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Cone angle (°)" Margin="0,0,0,6" />
                                    <TextBox x:Name="QueryAngleBox" Text="40" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Object categories" Margin="0,0,0,6" />
                            <WrapPanel Margin="0,0,0,14">
                                <CheckBox x:Name="BuildingsCheckBox" Content="Buildings" IsChecked="True" Margin="0,0,18,8" />
                                <CheckBox x:Name="VegetationCheckBox" Content="Vegetation" IsChecked="True" Margin="0,0,18,8" />
                                <CheckBox x:Name="RoadsCheckBox" Content="Roads" Margin="0,0,18,8" />
                                <CheckBox x:Name="WallsCheckBox" Content="Walls" Margin="0,0,18,8" />
                                <CheckBox x:Name="RocksCheckBox" Content="Rocks" Margin="0,0,18,8" />
                            </WrapPanel>

                            <TextBlock Text="Maximum returned objects per category" Margin="0,0,0,6" />
                            <TextBox x:Name="QueryLimitBox" Text="25" Margin="0,0,0,18" />

                            <Button x:Name="SendQueryButton" Content="Send query to Arma" Click="SendQueryButton_Click" IsEnabled="False" />
                            <TextBlock x:Name="QueryStatusText" Foreground="{StaticResource AccentBrush}"
                                       TextWrapping="Wrap" Margin="0,14,0,0" Text="Connect Arma 3 to enable queries." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Latest query result" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBox x:Name="QueryResultTextBox" IsReadOnly="True"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" AcceptsReturn="True" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="API keys">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" MaxWidth="760" HorizontalAlignment="Left">
                        <TextBlock Text="Credentials" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Keys are encrypted with Windows DPAPI for the current user. Voice audio and conversation content are never written to application logs."
                                   Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,22" />
                        <TextBlock Text="OpenAI API key" Margin="0,0,0,6" />
                        <PasswordBox x:Name="OpenAiKeyBox" Width="700" Margin="0,0,0,16" />
                        <TextBlock Text="ElevenLabs API key" Margin="0,0,0,6" />
                        <PasswordBox x:Name="ElevenLabsKeyBox" Width="700" Margin="0,0,0,16" />
                        <TextBlock Text="ElevenLabs voice ID" Margin="0,0,0,6" />
                        <TextBox x:Name="ElevenLabsVoiceIdBox" Width="700" Margin="0,0,0,16" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Save encrypted settings" Click="SaveSettingsButton_Click" />
                            <Button Content="Clear fields" Click="ClearSettingsButton_Click" />
                        </StackPanel>
                        <TextBlock x:Name="SettingsStatusText" Foreground="{StaticResource AccentBrush}" Margin="0,14,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Logs">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Open log folder" Click="OpenLogFolderButton_Click" />
                        <Button Content="Clear view" Click="ClearLogButton_Click" />
                    </StackPanel>
                    <ListBox x:Name="LogListBox" Grid.Row="2" Background="#0E1216"
                             BorderBrush="#3A4651" Foreground="{StaticResource TextBrush}"
                             FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="3" x:Name="FooterText" Text="Ready"
                   Foreground="{StaticResource MutedTextBrush}" Margin="0,12,0,0" />
    </Grid>
</Window>
