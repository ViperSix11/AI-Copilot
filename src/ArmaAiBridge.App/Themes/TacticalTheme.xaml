<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
      Papa Bear field-terminal palette: charcoal/olive equipment surfaces,
      desaturated green interaction accents, warm off-white body text, amber
      warnings and muted red destructive actions. Contrast and long-session
      readability take priority over decorative effects.
    -->
    <FontFamily x:Key="BodyFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="BrandFontFamily">Bahnschrift SemiBold, Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="TerminalFontFamily">Cascadia Mono, Consolas</FontFamily>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#10130F" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#151A13" />
    <SolidColorBrush x:Key="PanelBrush" Color="#1C231A" />
    <SolidColorBrush x:Key="PanelRaisedBrush" Color="#252D21" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#53604A" />
    <SolidColorBrush x:Key="StrongBorderBrush" Color="#728064" />
    <SolidColorBrush x:Key="InputBrush" Color="#0D110C" />
    <SolidColorBrush x:Key="TerminalBrush" Color="#0B100B" />
    <SolidColorBrush x:Key="TextBrush" Color="#F1F2E8" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#BCC5B3" />
    <SolidColorBrush x:Key="TerminalTextBrush" Color="#DCE9CF" />
    <SolidColorBrush x:Key="AccentBrush" Color="#9FBE83" />
    <SolidColorBrush x:Key="AccentStrongBrush" Color="#C2D99F" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#34432C" />
    <SolidColorBrush x:Key="WarningBrush" Color="#D9B86A" />
    <SolidColorBrush x:Key="DangerBrush" Color="#D07B70" />
    <SolidColorBrush x:Key="DangerDarkBrush" Color="#5A2D2A" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#899082" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#526B43" />

    <Style x:Key="TacticalFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Margin="2" Stroke="{StaticResource AccentStrongBrush}"
                               StrokeThickness="1" StrokeDashArray="2 2" SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource BodyFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="21" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="BrandTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BrandFontFamily}" />
        <Setter Property="FontSize" Value="27" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>

    <Style x:Key="SubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="LineHeight" Value="21" />
    </Style>

    <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BrandFontFamily}" />
        <Setter Property="FontSize" Value="19" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AccentStrongBrush}" />
        <Setter Property="LineHeight" Value="25" />
    </Style>

    <Style x:Key="MutedTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="TacticalPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="HeaderFaceplateStyle" TargetType="Border" BasedOn="{StaticResource TacticalPanelStyle}">
        <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrongBorderBrush}" />
        <Setter Property="Padding" Value="18,14" />
    </Style>

    <Style x:Key="TerminalPanelStyle" TargetType="Border" BasedOn="{StaticResource TacticalPanelStyle}">
        <Setter Property="Background" Value="{StaticResource TerminalBrush}" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrongBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Margin" Value="0,0,10,8" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource TacticalFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonChrome" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonChrome" Property="Background" Value="#43533A" />
                            <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonChrome" Property="Background" Value="#273121" />
                            <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
                            <Setter TargetName="ButtonChrome" Property="BorderThickness" Value="2" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                            <Setter TargetName="ButtonChrome" Property="Background" Value="#252A23" />
                            <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#41473D" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DestructiveButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource DangerDarkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
        <Setter Property="Foreground" Value="#FFF3F0" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentStrongBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource SelectionBrush}" />
        <Setter Property="SelectionOpacity" Value="0.8" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource TacticalFocusVisual}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
                <Setter Property="BorderThickness" Value="2" />
            </Trigger>
            <Trigger Property="IsReadOnly" Value="True">
                <Setter Property="CaretBrush" Value="Transparent" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                <Setter Property="Background" Value="#20241E" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TerminalTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="Background" Value="{StaticResource TerminalBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrongBorderBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource TerminalFontFamily}" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="Padding" Value="14" />
        <Setter Property="TextBlock.LineHeight" Value="21" />
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentStrongBrush}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource TacticalFocusVisual}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
                <Setter Property="BorderThickness" Value="2" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource TacticalFocusVisual}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="FontSize" Value="14" />
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AccentStrongBrush}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#485A3D" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource TacticalFocusVisual}" />
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="Padding" Value="18,11" />
        <Setter Property="Margin" Value="0,0,2,0" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource TacticalFocusVisual}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabChrome" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,1,1,0"
                            CornerRadius="3,3,0,0" Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabChrome" Property="Background" Value="{StaticResource PanelRaisedBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabChrome" Property="Background" Value="{StaticResource PanelBrush}" />
                            <Setter TargetName="TabChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="TabChrome" Property="BorderThickness" Value="1,1,1,3" />
                            <Setter Property="Foreground" Value="{StaticResource AccentStrongBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style x:Key="TerminalListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource {x:Type ListBox}}">
        <Setter Property="Background" Value="{StaticResource TerminalBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TerminalTextBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource TerminalFontFamily}" />
        <Setter Property="FontSize" Value="13.5" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource TerminalTextBrush}" />
        <Setter Property="Padding" Value="5,4" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="MinWidth" Value="14" />
        <Setter Property="MinHeight" Value="14" />
    </Style>

    <Style x:Key="StatusBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource StrongBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <Style x:Key="VersionBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="9,5" />
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="FontSize" Value="13" />
    </Style>
</ResourceDictionary>
